# ─── Namuna sozlamalar ────────────────────────────────────────────────
# Bu faylni nusxalab ".env" deb saqlang va o'z qiymatlaringizni yozing.
# .env ni HECH QACHON git/GitHub'ga yuklamang!

# Telegram bot tokeni (@BotFather dan olinadi) — MAJBURIY
BOT_TOKEN=your_bot_token_here

# Qo'llab-quvvatlash havolasi (ixtiyoriy)
SUPPORT_URL=https://t.me/your_support

# Kanalga obuna havolasi (ixtiyoriy)
CHANNEL_USERNAME=@your_channel

# ─── Vaqt sozlamalari (soniyada, ixtiyoriy) ───────────────────────────
# Kurslarni har necha soniyada tekshirish
AUTO_INTERVAL=600
# Kurs o'zgarmasa ham, kamida shu oraliqda bir xabar
NOTIFY_MIN_INTERVAL=3600

# ─── Texnik timeout'lar (ixtiyoriy) ───────────────────────────────────
FETCH_TIMEOUT=5
SOURCE_TIMEOUT=8
REFRESH_TIMEOUT=60
JS_RENDER_TIMEOUT=40

# Mantiqsiz kurslarni filtrlash (CBU atrofidagi band)
RATE_BAND_LO=0.80
RATE_BAND_HI=1.08
